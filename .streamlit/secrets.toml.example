# Copy this file to `secrets.toml` (in this same directory) and fill in your
# Azure AI Foundry credentials. `.streamlit/secrets.toml` is git-ignored.
#
# Streamlit auto-loads this into `st.secrets` at runtime.

[azure_llm]
endpoint        = "https://dgm-foundry.services.ai.azure.com/anthropic/"
deployment_name = "claude-sonnet-4-6"
api_key         = "YOUR_API_KEY"
max_tokens      = 2048
